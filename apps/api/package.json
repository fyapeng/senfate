{
  "name": "@senfate/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": { "@senfate/contracts": "workspace:*", "@senfate/core": "workspace:*", "@senfate/ephemeris": "workspace:*", "@senfate/locations": "workspace:*" },
  "devDependencies": { "wrangler": "4.113.0" },
  "scripts": {
    "dev": "wrangler dev",
    "types": "wrangler types src/env.d.ts",
    "typecheck": "pnpm types && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "pnpm types && wrangler deploy --dry-run --outdir dist"
  }
}
