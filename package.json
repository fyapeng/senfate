{
  "name": "senfate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @senfate/web dev",
    "dev:api": "pnpm --filter @senfate/api dev",
    "audit:rules": "pnpm --filter @senfate/rules run audit",
    "audit:reference-compilation": "pnpm --filter @senfate/rules run audit:compilation",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm --filter @senfate/web build && pnpm --filter @senfate/api build",
    "verify": "pnpm audit:rules && pnpm audit:reference-compilation && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "24.10.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
